import torch
from transformers import AutoModelForCausalLM, AutoTokenizer
from peft import PeftModel

# ================= 路径配置 (已填好) =================
BASE_MODEL_PATH = "/home/mac/PycharmProjects/PythonProject/yoyo/models/Qwen2.5-Coder-7B-Instruct"
LORA_PATH = "/home/mac/PycharmProjects/PythonProject/yoyo/solhint/lora/solidity_lintseq"
# ====================================================

def clean_lintseq_output(text):
    """
    辅助函数：把模型生成的 Diff 格式清洗成纯代码
    """
    lines = text.split('\n')
    cleaned_lines = []
    for line in lines:
        # 1. 忽略 Diff 头
        if line.startswith('@@') and line.endswith('@@'):
            continue
        # 2. 忽略删除行
        if line.startswith('-'):
            continue
        # 3. 提取新增行 (去掉+)
        if line.startswith('+'):
            cleaned_lines.append(line[1:]) 
        # 4. 保留普通行 (有些模型可能混合输出)
        elif not line.startswith('@@') and not line.startswith('-'):
            cleaned_lines.append(line)
            
    return '\n'.join(cleaned_lines)

def main():
    print("🚀 正在加载模型 (这可能需要几秒钟)...")
    
    # 1. 加载 Tokenizer
    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL_PATH, trust_remote_code=True)
    
    # 2. 加载基座 (BF16 + SDPA加速)
    base_model = AutoModelForCausalLM.from_pretrained(
        BASE_MODEL_PATH,
        torch_dtype=torch.bfloat16,
        device_map="auto",
        attn_implementation="sdpa",
        trust_remote_code=True
    )
    
    # 3. 挂载 LoRA
    print(f"🔗 正在挂载 LoRA: {LORA_PATH}")
    model = PeftModel.from_pretrained(base_model, LORA_PATH)
    model.eval()

    # ================= 📝 在这里修改你的测试题目 =================
    instruction = "Create a simple Auction smart contract where users can bid and the highest bidder wins."
    # ==========================================================

    print(f"\n❓ 测试题目: {instruction}")
    print("🤖 正在生成... (观察是否出现 Diff 格式)")
    print("="*60)

    # 构造 Prompt
    messages = [{"role": "user", "content": instruction}]
    text = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    inputs = tokenizer([text], return_tensors="pt").to(model.device)

    # 推理
    with torch.no_grad():
        generated_ids = model.generate(
            **inputs,
            max_new_tokens=1024,
            temperature=0.2, # 低温，保证代码逻辑严谨
            top_p=0.9,
            do_sample=True
        )

    # 解码
    generated_ids = [
        output_ids[len(input_ids):] for input_ids, output_ids in zip(inputs.input_ids, generated_ids)
    ]
    raw_response = tokenizer.batch_decode(generated_ids, skip_special_tokens=True)[0]

    # --- 展示结果 ---
    print("\n📦 [RAW OUTPUT] 模型原始输出 (验证 LintSeq 格式):")
    print("-" * 30)
    print(raw_response)
    print("-" * 30)

    print("\n✨ [CLEAN CODE] 清洗后的 Solidity 代码:")
    print("-" * 30)
    final_code = clean_lintseq_output(raw_response)
    print(final_code)
    print("="*60)

if __name__ == "__main__":
    main()
